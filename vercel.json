{
  "version": 2,
  "routes": [
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/users", "dest": "/api/users.js" },
    { "src": "/api/reset-password", "dest": "/api/reset-password.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
